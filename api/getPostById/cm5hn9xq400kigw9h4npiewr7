/span><br><span class=\"line\">                content = content.replace(old_tag, new_tag)</span><br><span class=\"line\">                updated = <span class=\"literal\">True</span></span><br><span class=\"line\">                <span class=\"keyword\">if</span> <span class=\"string\">&#x27;/images/cover/&#x27;</span> <span class=\"keyword\">in</span> old_tag:</span><br><span class=\"line\">                    log(<span class=\"string\">f&quot; 替换 cover 标签 &quot;</span>)</span><br><span class=\"line\">                    content = content.replace(<span class=\"string\">&#x27;cover: &#x27;</span> + extract_image_url_from_tag(old_tag), <span class=\"string\">&#x27;cover: &#x27;</span> + extract_image_url_from_tag(new_tag))</span><br><span class=\"line\"></span><br><span class=\"line\">        <span class=\"comment\"># 只有在有更新时才写回文件</span></span><br><span class=\"line\">        <span class=\"keyword\">if</span> updated:</span><br><span class=\"line\">            file.seek(<span class=\"number\">0</span>)</span><br><span class=\"line\">            file.write(content)</span><br><span class=\"line\">            file.truncate()</span><br><span class=\"line\">        <span class=\"keyword\">else</span>:</span><br><span class=\"line\">            <span class=\"built_in\">print</span>(<span class=\"string\">f&quot; 文件 <span class=\"subst\">&#123;md_file&#125;</span> 中没有需要更新的图片标签。&quot;</span>)</span><br><span class=\"line\"></span><br><span class=\"line\"><span class=\"keyword\">def</span> <span class=\"title function_\">get_referenced_images</span>(<span class=\"params\">md_file</span>):</span><br><span class=\"line\">    <span class=\"string\">&quot;&quot;&quot;</span></span><br><span class=\"line\"><span class=\"string\">    获取 Markdown 文件中引用的所有图片。</span></span><br><span class=\"line\"><span class=\"string\">    &quot;&quot;&quot;</span></span><br><span class=\"line\">    <span class=\"keyword\">with</span> <span class=\"built_in\">open</span>(md_file, <span class=\"strin