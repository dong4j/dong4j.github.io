123;</span><br><span class=\"line\">                    JOptionPane.showMessageDialog(<span class=\"literal\">null</span>,number1+<span class=\"string\">&quot; / &quot;</span>+number2+<span class=\"string\">&quot; = &quot;</span>+(number1/number2));</span><br><span class=\"line\">                &#125;<span class=\"keyword\">else</span></span><br><span class=\"line\">                    JOptionPane.showMessageDialog(<span class=\"literal\">null</span>,<span class=\"string\">&quot; 被除数不能为 0&quot;</span>);</span><br><span class=\"line\">                <span class=\"keyword\">break</span>;</span><br><span class=\"line\">            &#125;</span><br><span class=\"line\"></span><br><span class=\"line\">        &#125;</span><br><span class=\"line\">    &#125;</span><br><span class=\"line\">&#125;</span><br><span class=\"line\"><span class=\"keyword\">class</span> <span class=\"title class_\">OperationTest</span> &#123;</span><br><span class=\"line\">    <span class=\"keyword\">public</span> <span class=\"keyword\">static</span> <span class=\"keyword\">void</span> <span class=\"title function_\">main</span><span class=\"params\">(String[] args)</span> &#123;</span><br><span class=\"line\">        <span class=\"keyword\">while</span>(<span class=\"literal\">true</span>)&#123;</span><br><span class=\"line\">            <span class=\"keyword\">try</span>&#123;<span class=\"comment\">//try catch 语句是为了判断输入是否符合要求, 如果不是一个数字, 则转到 catch 语句</span></span><br><span class=\"line\">                <span class=\"type\">String</span> <span class=\"variable\">s1</span> <span class=\"operator\">=</span> JOptionPane.showInputDialog(<span class=\"literal\">null</span>,<span class=\"string\">&quot; 请输入第一个数 &quot;</span>);</span><br><span class=\"line\">                <span class=\"type\">String</span> <span class=\"variable\">s2</span> <span class=\"operator\">=</span> JOptionPane.showInputDialog(<span class=\"literal\">null</span>,<span class=\"string\">&quot; 请输入第二个数 &quot;</span>);</span>